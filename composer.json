{
    "name": "web-fu/simple-repository",
    "description": "Repository pattern implementation for small or old projects",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "WebFu\\SimpleRepository\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebFu\\SimpleRepository\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Gabriele Manganello",
            "email": "info@web-fu.it",
            "homepage": "https://web-fu.it"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.13",
        "phpstan/phpstan": "^1.9"
    },
    "scripts": {
        "cs": "PHP_CS_FIXER_IGNORE_ENV=1 php ./vendor/bin/php-cs-fixer fix --dry-run --allow-risky=yes --stop-on-violation",
        "cs:fix": "PHP_CS_FIXER_IGNORE_ENV=1 php ./vendor/bin/php-cs-fixer fix --allow-risky yes --show-progress dots --verbose",
        "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1",
        "tests": "./vendor/bin/phpunit --stop-on-failure",
        "ci": [
            "@autoload",
            "@parallel cs phpstan tests"
        ]
    }
}
